---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BuildingCard from '../../components/BuildingCard.astro';
import Pager from '../../components/Pager.astro';
import registryData from '../../data/buildings-registry.json';
import { useT } from '../../i18n/ui';

const lang = 'en';
const t = useT(lang);

// 英語版は翻訳済み(buildingsEn)の建物のみ掲載。数値はJP版から補う。
const jp = await getCollection('buildings');
const jpBySlug = new Map(jp.map((p) => [p.slug, p]));
const allPosts = (await getCollection('buildings-en'))
  .map((en) => ({ en, jp: jpBySlug.get(en.slug) }))
  .filter((x) => x.jp)
  .sort((a, b) => b.jp!.data.publishedAt.valueOf() - a.jp!.data.publishedAt.valueOf());

// 1ページ20件・新着順。21件目以降は /en/page/2/ … へ。
const PER_PAGE = 20;
const totalPages = Math.max(1, Math.ceil(allPosts.length / PER_PAGE));
const posts = allPosts.slice(0, PER_PAGE);

// 建物の収録数は言語共通の母数(レジストリ ∪ 記事)。記事数は英語化済みの本数。
const slugs = new Set<string>((registryData as any).buildings.map((b: any) => b.slug));
for (const p of jp) slugs.add(p.slug);
const buildingCount = slugs.size;
const articleCount = allPosts.length;
---
<BaseLayout title="Built Japan" lang={lang} altPath="/">
  <section class="home-hero">
    <div class="home-hero-inner" data-reveal>
      <p class="eyebrow">{t('home.eyebrow')}</p>
      <h1>{t('home.title')}</h1>
      <p class="home-hero-desc">{t('home.desc')}</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="/en/database/">{t('home.cta.database')}</a>
        <a class="btn btn-ghost" href="/rankings/">{t('home.cta.rankings')}</a>
      </div>
      <ul class="hero-stats">
        <li><b>{buildingCount}</b><span>{t('home.stat.buildings')}</span></li>
        <li><b>{articleCount}</b><span>{t('home.stat.articles')}</span></li>
        <li><b>JP / EN</b><span>{t('home.stat.bilingual')}</span></li>
      </ul>
    </div>
    <div class="hero-skyline" aria-hidden="true"></div>
  </section>

  <div class="section-head" data-reveal>
    <h2>{t('home.section.latest')}</h2>
    <p>{t('home.section.latest.desc')}</p>
  </div>

  <section class="grid grid-2">
    {posts.map(({ en, jp }) => (
      <BuildingCard
        lang={lang}
        url={`/en/buildings/${en.slug}/`}
        title={en.data.title}
        buildingType={jp!.data.buildingType}
        area={en.data.area}
        completedYear={jp!.data.completedYear}
        heightM={jp!.data.heightM}
        summary={en.data.summary}
        verified={jp!.data.verified}
        heroImage={jp!.data.heroImage}
      />
    ))}
  </section>

  <Pager current={1} total={totalPages} basePath="/en/" lang={lang} />
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BuildingArticle from '../../../components/BuildingArticle.astro';
import { buildSpecs } from '../../../i18n/ui';

export async function getStaticPaths() {
  const jp = await getCollection('buildings');
  const jpBySlug = new Map(jp.map((p) => [p.slug, p]));
  const en = await getCollection('buildings-en');
  // 数値の出典となるJP版が存在する英語記事だけをページ化する。
  return en
    .filter((post) => jpBySlug.has(post.slug))
    .map((post) => ({
      params: { slug: post.slug },
      props: { post, jp: jpBySlug.get(post.slug)! },
    }));
}

const lang = 'en';
const { post, jp } = Astro.props;
const { Content } = await post.render();
const e = post.data;
const f = jp.data; // 数値の事実（言語非依存）

// 英語表記が無いフィールドは日本語版にフォールバック
const developer = e.developer ?? f.developer;
const architect = e.architect ?? f.architect;

const pageUrl = new URL(`/en/buildings/${post.slug}/`, Astro.site ?? 'https://example.com').toString();
const metaDescription =
  e.summary ?? `${e.title}${f.completedYear ? ` (completed ${f.completedYear})` : ''} — a record of architecture and redevelopment in ${e.area}, Tokyo.`;

const buildingLd: Record<string, unknown> = {
  '@type': f.buildingType === 'residence' ? 'ApartmentComplex' : 'LandmarksOrHistoricalBuildings',
  name: e.title,
  address: { '@type': 'PostalAddress', addressLocality: e.area, addressRegion: 'Tokyo', addressCountry: 'JP' },
};
if (f.address) (buildingLd.address as Record<string, unknown>).streetAddress = f.address;
const base = (Astro.site ?? new URL('https://example.com')).toString().replace(/\/$/, '');
const iso = f.publishedAt.toISOString();
// Article(画像/更新日/著者/発行者ロゴまで補完しリッチリザルト対象に) + パンくずを1つの@graphで出力。
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      headline: e.title,
      description: metaDescription,
      inLanguage: 'en',
      datePublished: iso,
      dateModified: iso,
      mainEntityOfPage: pageUrl,
      ...(f.heroImage ? { image: [f.heroImage] } : {}),
      author: { '@type': 'Organization', name: 'Built Japan', url: `${base}/` },
      publisher: {
        '@type': 'Organization',
        name: 'Built Japan',
        logo: { '@type': 'ImageObject', url: `${base}/ogp.png` },
      },
      about: buildingLd,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${base}/en/` },
        { '@type': 'ListItem', position: 2, name: e.title, item: pageUrl },
      ],
    },
  ],
};

const specs = buildSpecs(lang, {
  buildingType: f.buildingType,
  area: e.area,
  completedYear: f.completedYear,
  floorsAbove: f.floorsAbove,
  floorsBelow: f.floorsBelow,
  heightM: f.heightM,
  totalFloorAreaM2: f.totalFloorAreaM2,
  developer,
  architect,
});

// 検索意図に寄せたSEOタイトル。H1は e.title のまま。
const typeLabelEn = f.buildingType === 'residence' ? 'residential tower' : 'office tower';
const factBitsEn = [
  f.completedYear ? `Completed ${f.completedYear}` : null,
  f.heightM ? `${f.heightM}m` : null,
].filter(Boolean).join(', ');
const seoTitle = `${e.title}${factBitsEn ? ` | ${factBitsEn}` : ''} | ${e.area} ${typeLabelEn}`;

// 内部リンク用の関連記事(英語ページがある建物のみ)。同エリア優先→竣工年が近い順。最大4件。
const enBySlug = new Map((await getCollection('buildings-en')).map((p) => [p.slug, p.data]));
const related = (await getCollection('buildings'))
  .filter((p) => p.slug !== post.slug && enBySlug.has(p.slug))
  .map((p) => {
    const sameArea = p.data.area === f.area ? 1000 : 0;
    const gap = f.completedYear && p.data.completedYear ? Math.abs(p.data.completedYear - f.completedYear) : 999;
    return { p, score: sameArea - gap };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, 4)
  .map(({ p }) => {
    const en = enBySlug.get(p.slug)!;
    return { title: en.title, area: en.area, href: `/en/buildings/${p.slug}/` };
  });
---
<BaseLayout title={seoTitle} description={metaDescription} lang={lang} ogType="article" altPath={`/buildings/${post.slug}/`} jsonLd={jsonLd} appendSiteName={false} ogImage={f.heroImage}>
  <BuildingArticle
    lang={lang}
    title={e.title}
    summary={e.summary}
    related={related}
    area={e.area}
    buildingType={f.buildingType}
    verified={f.verified}
    heroImage={f.heroImage}
    heroImageCredit={f.heroImageCredit}
    heroImageLink={f.heroImageLink}
    specs={specs}
    tags={e.tags}
    tagBase="/en/tags/"
    sources={f.sources}
    listPath="/en/"
    searchTitle={f.title}
    searchArea={f.area}
    lat={f.lat}
    lng={f.lng}
    mapLabel={f.title}
  >
    <Content />
  </BuildingArticle>
</BaseLayout>

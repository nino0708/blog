---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BuildingArticle from '../../components/BuildingArticle.astro';
import { buildSpecs } from '../../i18n/ui';

export async function getStaticPaths() {
  const posts = await getCollection('buildings');
  const enSlugs = new Set((await getCollection('buildings-en')).map((p) => p.slug));
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, hasEn: enSlugs.has(post.slug) },
  }));
}

const lang = 'ja';
const { post, hasEn } = Astro.props;
const { Content } = await post.render();
const d = post.data;

const pageUrl = new URL(`/buildings/${post.slug}/`, Astro.site ?? 'https://example.com').toString();
const metaDescription =
  d.summary ?? `${d.title}（${d.area}${d.completedYear ? `・${d.completedYear}年竣工` : ''}）の建築・再開発の記録。`;

// 構造化データ: 記事(Article) + 主題の建物(該当する建築タイプ)
const buildingLd: Record<string, unknown> = {
  '@type': d.buildingType === 'residence' ? 'ApartmentComplex' : 'LandmarksOrHistoricalBuildings',
  name: d.title,
  address: { '@type': 'PostalAddress', addressLocality: d.area, addressRegion: '東京都', addressCountry: 'JP' },
};
if (d.address) (buildingLd.address as Record<string, unknown>).streetAddress = d.address;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: d.title,
  description: metaDescription,
  inLanguage: 'ja',
  datePublished: d.publishedAt.toISOString(),
  mainEntityOfPage: pageUrl,
  about: buildingLd,
  publisher: { '@type': 'Organization', name: 'Tokyo Towers Journal' },
};

const specs = buildSpecs(lang, d);
const altPath = hasEn ? `/en/buildings/${post.slug}/` : null;

// 検索意図に寄せたSEOタイトル(建物名｜竣工年・高さ｜エリア+用途)。H1はd.titleのまま。
const typeLabelJa = d.buildingType === 'residence' ? 'マンション' : 'オフィスビル';
const factBits = [
  d.completedYear ? `${d.completedYear}年竣工` : null,
  d.heightM ? `高さ${d.heightM}m` : null,
].filter(Boolean).join(' ');
const seoTitle = `${d.title}｜${factBits ? `${factBits}｜` : ''}${d.area}の${typeLabelJa}`;

// 内部リンク用の関連記事: 同エリア優先、次に竣工年が近い順。最大4件。
const related = (await getCollection('buildings'))
  .filter((p) => p.slug !== post.slug)
  .map((p) => {
    const sameArea = p.data.area === d.area ? 1000 : 0;
    const gap = d.completedYear && p.data.completedYear ? Math.abs(p.data.completedYear - d.completedYear) : 999;
    return { p, score: sameArea - gap };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, 4)
  .map(({ p }) => ({ title: p.data.title, area: p.data.area, href: `/buildings/${p.slug}/` }));
---
<BaseLayout title={seoTitle} description={metaDescription} lang={lang} ogType="article" altPath={altPath} jsonLd={jsonLd} appendSiteName={false}>
  <BuildingArticle
    lang={lang}
    title={d.title}
    summary={d.summary}
    related={related}
    area={d.area}
    buildingType={d.buildingType}
    verified={d.verified}
    heroImage={d.heroImage}
    heroImageCredit={d.heroImageCredit}
    heroImageLink={d.heroImageLink}
    specs={specs}
    tags={d.tags}
    tagBase="/tags/"
    sources={d.sources}
    listPath="/"
  >
    <Content />
  </BuildingArticle>
</BaseLayout>

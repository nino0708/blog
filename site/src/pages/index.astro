---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BuildingCard from '../components/BuildingCard.astro';
import registryData from '../data/buildings-registry.json';
import { useT } from '../i18n/ui';

const lang = 'ja';
const t = useT(lang);
const posts = (await getCollection('buildings')).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

// ヒーローのスタッツ用カウント（図鑑と同じ母数: レジストリ ∪ 記事）。
const slugs = new Set<string>((registryData as any).buildings.map((b: any) => b.slug));
for (const p of posts) slugs.add(p.slug);
const buildingCount = slugs.size;
const articleCount = posts.length;
---
<BaseLayout title="Built Japan" lang={lang} altPath="/en/">
  <section class="home-hero">
    <div class="home-hero-inner" data-reveal>
      <p class="eyebrow">{t('home.eyebrow')}</p>
      <h1>{t('home.title')}</h1>
      <p class="home-hero-desc">{t('home.desc')}</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="/database/">{t('home.cta.database')}</a>
        <a class="btn btn-ghost" href="/rankings/">{t('home.cta.rankings')}</a>
      </div>
      <ul class="hero-stats">
        <li><b>{buildingCount}</b><span>{t('home.stat.buildings')}</span></li>
        <li><b>{articleCount}</b><span>{t('home.stat.articles')}</span></li>
        <li><b>JP / EN</b><span>{t('home.stat.bilingual')}</span></li>
      </ul>
    </div>
    <div class="hero-skyline" aria-hidden="true"></div>
  </section>

  <div class="section-head" data-reveal>
    <h2>{t('home.section.latest')}</h2>
    <p>{t('home.section.latest.desc')}</p>
  </div>

  <div class="grid-sort" data-reveal>
    <label class="home-sort">
      <span>{t('home.sort.label')}</span>
      <select id="home-sort" aria-label={t('home.sort.label')}>
        <option value="latest">{t('home.sort.latest')}</option>
        <option value="name">{t('home.sort.name')}</option>
        <option value="newest">{t('home.sort.newest')}</option>
        <option value="oldest">{t('home.sort.oldest')}</option>
        <option value="height">{t('home.sort.height')}</option>
      </select>
    </label>
  </div>

  <section class="grid" id="home-grid">
    {posts.map((post) => (
      <BuildingCard
        lang={lang}
        url={`/buildings/${post.slug}/`}
        title={post.data.title}
        buildingType={post.data.buildingType}
        area={post.data.area}
        completedYear={post.data.completedYear}
        heightM={post.data.heightM}
        summary={post.data.summary}
        verified={post.data.verified}
        heroImage={post.data.heroImage}
      />
    ))}
  </section>

  <script is:inline define:vars={{ lang }}>
    (function () {
      const grid = document.getElementById('home-grid');
      const sel = document.getElementById('home-sort');
      if (!grid || !sel) return;
      const cards = [...grid.querySelectorAll('.card')];
      // 初期DOM順（= 新着順）を控える。
      cards.forEach((c, i) => (c.dataset.order = String(i)));

      const num = (v) => {
        const n = parseFloat(v);
        return Number.isFinite(n) ? n : null;
      };

      function sortBy(mode) {
        const sorted = cards.slice().sort((a, b) => {
          if (mode === 'latest') {
            return Number(a.dataset.order) - Number(b.dataset.order);
          }
          if (mode === 'name') {
            return a.dataset.name.localeCompare(b.dataset.name, lang === 'ja' ? 'ja' : 'en');
          }
          // year / height は数値降順・昇順。値の無いものは常に末尾。
          const key = mode === 'height' ? 'height' : 'year';
          const va = num(a.dataset[key]);
          const vb = num(b.dataset[key]);
          if (va === null && vb === null) return Number(a.dataset.order) - Number(b.dataset.order);
          if (va === null) return 1;
          if (vb === null) return -1;
          return mode === 'oldest' ? va - vb : vb - va;
        });
        for (const c of sorted) grid.appendChild(c);
      }

      sel.addEventListener('change', () => sortBy(sel.value));
    })();
  </script>

  <style>
    .grid-sort {
      display: flex;
      justify-content: flex-end;
      margin: 0 0 14px;
    }
    .home-sort {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.82rem;
      color: var(--text-muted);
    }
    .home-sort select {
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 8px 10px;
      background: var(--surface);
      color: var(--text);
      font-size: 0.85rem;
    }
    .home-sort select:focus { outline: none; border-color: var(--brand); }
  </style>
</BaseLayout>

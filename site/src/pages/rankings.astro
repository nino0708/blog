---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = '関東の高層ビル ランキング｜高さ・延床面積 Top5';
const description =
  '関東（東京・神奈川）の高層ビルを「高さ」と「延床面積（規模）」の2軸でランキング。麻布台ヒルズ森JPタワー、横浜ランドマークタワー、大手町プレイスなど、関東を代表する超高層建築をまとめました。';

// 高さは各種公開情報(Wikipedia「日本の超高層建築物・構築物の一覧」等)に基づく。塔(東京タワー等)は除く。
const heightRanking = [
  { rank: 1, name: '麻布台ヒルズ 森JPタワー', meta: '高さ 325.4m', year: 2023, area: '港区', slug: 'azabudai-hills-mori-jp-tower' },
  { rank: 2, name: '横浜ランドマークタワー', meta: '高さ 296.33m', year: 1993, area: '横浜市西区', slug: 'yokohama-landmark-tower' },
  { rank: 3, name: '虎ノ門ヒルズ ステーションタワー', meta: '高さ 265.75m', year: 2023, area: '港区', slug: 'toranomon-hills-station-tower' },
  { rank: 4, name: '麻布台ヒルズ レジデンスB', meta: '高さ 262.82m', year: 2025, area: '港区', slug: 'azabudai-hills-residence-b' },
  { rank: 5, name: '東京ミッドタウン・タワー', meta: '高さ 248.1m', year: 2007, area: '港区', slug: 'tokyo-midtown-tower' },
];

// 延床面積は単体の超高層ビル(複合施設群=サンシャインシティ等は除く)。各種公開情報に基づく。
const floorRanking = [
  { rank: 1, name: '横浜ランドマークタワー', meta: '延床 392,885㎡', year: 1993, area: '横浜市西区', slug: 'yokohama-landmark-tower' },
  { rank: 2, name: 'ザ・東京タワーズ', meta: '延床 383,340㎡', year: 2008, area: '中央区', slug: 'the-tokyo-towers' },
  { rank: 3, name: '東京都庁第一本庁舎', meta: '延床 381,692㎡', year: 1990, area: '新宿区', slug: 'tokyo-metropolitan-government-no1' },
  { rank: 4, name: '六本木ヒルズ 森タワー', meta: '延床 379,409㎡', year: 2003, area: '港区', slug: 'roppongi-hills-mori-tower' },
  { rank: 5, name: '大手町プレイス', meta: '延床 354,000㎡', year: 2018, area: '千代田区', slug: 'otemachi-place' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: '関東の高層ビル 高さランキング Top5',
  itemListElement: heightRanking.map((r) => ({
    '@type': 'ListItem',
    position: r.rank,
    name: r.name,
    url: `https://builtjapan.com/buildings/${r.slug}/`,
  })),
};
---
<BaseLayout title={title} description={description} lang="ja" appendSiteName={false} jsonLd={jsonLd}>
  <p class="breadcrumb"><a href="/">記事一覧</a> ／ ランキング</p>
  <article class="article">
    <h1>関東の高層ビル ランキング</h1>
    <p class="lead">{description}</p>

    <h2>高さランキング Top5</h2>
    <ol class="ranking-list">
      {heightRanking.map((r) => (
        <li>
          <span class="rank-no">{r.rank}</span>
          <div class="rank-body">
            <a class="rank-name" href={`/buildings/${r.slug}/`}>{r.name}</a>
            <span class="rank-meta">{r.meta} ・ {r.year}年竣工 ・ {r.area}</span>
          </div>
        </li>
      ))}
    </ol>
    <p class="rank-note">※ 完成済みのビル（建築物）が対象。東京スカイツリーや東京タワー等の塔（構造物）は除く。2028年竣工予定のTorch Tower（約390m）など建設中の建物は含みません。</p>

    <h2 style="margin-top:40px">延床面積（規模）ランキング Top5</h2>
    <p class="lead">建物の「大きさ」を延床面積で見たランキング。高さでは上位でなくても、規模では関東屈指の存在です。</p>
    <ol class="ranking-list">
      {floorRanking.map((r) => (
        <li>
          <span class="rank-no">{r.rank}</span>
          <div class="rank-body">
            <a class="rank-name" href={`/buildings/${r.slug}/`}>{r.name}</a>
            <span class="rank-meta">{r.meta} ・ {r.year}年竣工 ・ {r.area}</span>
          </div>
        </li>
      ))}
    </ol>
    <p class="rank-note">※ 単体の超高層ビルが対象（サンシャインシティ・東京ミッドタウン等の複合施設街区は除く）。延床面積は各種公開情報（不動産メディアのランキング、Wikipedia等）に基づく目安です。</p>
  </article>
</BaseLayout>

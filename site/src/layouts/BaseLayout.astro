---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { useT, ogLocale, type Lang } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  /** ページ言語。ja はルート、en は /en 配下 */
  lang?: Lang;
  /** og:type。記事ページは 'article' */
  ogType?: string;
  /**
   * もう一方の言語での同一ページのパス（例: '/en/buildings/x/'）。
   * 翻訳が存在しないページでは null を渡す（その場合 hreflang alternate は出さない）。
   */
  altPath?: string | null;
  /** 追加で差し込む構造化データ(JSON-LD)など。head末尾に出力 */
  jsonLd?: Record<string, unknown>;
  /** <title>末尾にサイト名を付けるか。SEO最適化済みの記事タイトルは付けない(長くなるため) */
  appendSiteName?: boolean;
}
const siteName = 'Tokyo Towers Journal';
const {
  title,
  lang = 'ja',
  ogType = 'website',
  altPath = null,
  jsonLd,
  appendSiteName = true,
} = Astro.props;
const t = useT(lang);
const description = Astro.props.description ?? t('site.description');

const fullTitle = appendSiteName && title !== siteName ? `${title} | ${siteName}` : title;
const siteBase = Astro.site ?? new URL('https://example.com');
// site 未設定(example.com)でも壊れないよう Astro.site をフォールバック
const canonical = new URL(Astro.url.pathname, siteBase).toString();
const ogImage = new URL('/ogp.svg', siteBase).toString();
const altUrl = altPath ? new URL(altPath, siteBase).toString() : null;
// hreflang: 自言語=canonical、もう一方=altUrl。x-default は日本語(ルート)を指す。
const jaUrl = lang === 'ja' ? canonical : altUrl;
const enUrl = lang === 'en' ? canonical : altUrl;

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: siteBase.toString(),
  inLanguage: lang,
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- 多言語の相互リンク(hreflang) -->
    {jaUrl && <link rel="alternate" hreflang="ja" href={jaUrl} />}
    {enUrl && <link rel="alternate" hreflang="en" href={enUrl} />}
    {jaUrl && <link rel="alternate" hreflang="x-default" href={jaUrl} />}

    <!-- Open Graph -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale[lang]} />
    {altUrl && <meta property="og:locale:alternate" content={ogLocale[lang === 'ja' ? 'en' : 'ja']} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap.xml" />

    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <Header lang={lang} altPath={altPath} />
    <main class="container">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>

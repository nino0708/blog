---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { useT, ogLocale, type Lang } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  /** ページ言語。ja はルート、en は /en 配下 */
  lang?: Lang;
  /** og:type。記事ページは 'article' */
  ogType?: string;
  /**
   * もう一方の言語での同一ページのパス（例: '/en/buildings/x/'）。
   * 翻訳が存在しないページでは null を渡す（その場合 hreflang alternate は出さない）。
   */
  altPath?: string | null;
  /** 追加で差し込む構造化データ(JSON-LD)など。head末尾に出力 */
  jsonLd?: Record<string, unknown>;
  /** <title>末尾にサイト名を付けるか。SEO最適化済みの記事タイトルは付けない(長くなるため) */
  appendSiteName?: boolean;
  /** OGP/Twitterカード画像のURL。記事はheroImage(建物写真)を渡す。未指定は /ogp.png */
  ogImage?: string;
  /** 検索エンジンにインデックスさせないページ(404・薄いユーティリティページ等)で true */
  noindex?: boolean;
}
const siteName = 'Built Japan';
const {
  title,
  lang = 'ja',
  ogType = 'website',
  altPath = null,
  jsonLd,
  appendSiteName = true,
  ogImage,
  noindex = false,
} = Astro.props;
const t = useT(lang);
const description = Astro.props.description ?? t('site.description');

const fullTitle = appendSiteName && title !== siteName ? `${title} | ${siteName}` : title;
const siteBase = Astro.site ?? new URL('https://example.com');
// site 未設定(example.com)でも壊れないよう Astro.site をフォールバック
const canonical = new URL(Astro.url.pathname, siteBase).toString();
// 記事は建物写真(絶対URL)をOG画像に。未指定/相対は既定の /ogp.png にフォールバック。
// SVGはX/Facebook/LINE等がOGカードで描画しないためPNG(1200×630)を既定にする。
const ogImageUrl = ogImage
  ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteBase).toString())
  : new URL('/ogp.png', siteBase).toString();
const altUrl = altPath ? new URL(altPath, siteBase).toString() : null;
// hreflang: 自言語=canonical、もう一方=altUrl。x-default は日本語(ルート)を指す。
const jaUrl = lang === 'ja' ? canonical : altUrl;
const enUrl = lang === 'en' ? canonical : altUrl;

const orgUrl = siteBase.toString();
const logoUrl = new URL('/ogp.png', siteBase).toString();
// サイト全体のエンティティ。WebSite と Organization を @id で相互参照し、ブランド認識を補強する。
const websiteLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${orgUrl}#website`,
      name: siteName,
      url: orgUrl,
      inLanguage: lang,
      publisher: { '@id': `${orgUrl}#org` },
    },
    {
      '@type': 'Organization',
      '@id': `${orgUrl}#org`,
      name: siteName,
      url: orgUrl,
      logo: { '@type': 'ImageObject', url: logoUrl },
      sameAs: ['https://x.com/builtjapan'],
    },
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- JS有効を示すクラスを描画前に付与(スクロール演出の初期非表示はJS有効時のみ＝no-JSでも内容は必ず表示) -->
    <script is:inline>document.documentElement.classList.add('js');</script>
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonical} />

    <!-- 多言語の相互リンク(hreflang) -->
    {jaUrl && <link rel="alternate" hreflang="ja" href={jaUrl} />}
    {enUrl && <link rel="alternate" hreflang="en" href={enUrl} />}
    {jaUrl && <link rel="alternate" hreflang="x-default" href={jaUrl} />}

    <!-- Open Graph -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={title} />
    {!ogImage && <meta property="og:image:type" content="image/png" />}
    {!ogImage && <meta property="og:image:width" content="1200" />}
    {!ogImage && <meta property="og:image:height" content="630" />}
    <meta property="og:locale" content={ogLocale[lang]} />
    {altUrl && <meta property="og:locale:alternate" content={ogLocale[lang === 'ja' ? 'en' : 'ja']} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@builtjapan" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap.xml" />

    <!-- 見出し・ロゴ用のディスプレイフォント(端正な日本語ゴシック)。本文はOS標準のまま。 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@500;700;900&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    {/* Cloudflare Web Analytics (Cookie不要・軽量。流入元/国/PVを計測。tokenは公開値) */}
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "16491eb520064b6fa0fa463cabda6dd1"}'
    ></script>
  </head>
  <body>
    <a class="skip-link" href="#main">{t('a11y.skip')}</a>
    <Header lang={lang} altPath={altPath} />
    <main id="main" class="container">
      <slot />
    </main>
    <Footer lang={lang} />

    <!-- スクロール演出: [data-reveal] が視界に入ったら .is-in を付けてフェードアップ(追加のみ・描画ロジック非干渉) -->
    <script is:inline>
      (function () {
        var els = document.querySelectorAll('[data-reveal]');
        if (!els.length) return;
        var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !('IntersectionObserver' in window)) {
          els.forEach(function (el) { el.classList.add('is-in'); });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (!e.isIntersecting) return;
            var el = e.target;
            // 同じ親の中での順番に応じて軽くずらして“流れる”演出に(最大240ms)
            var sibs = el.parentElement ? [].indexOf.call(el.parentElement.children, el) : 0;
            el.style.transitionDelay = Math.min(sibs % 12, 6) * 40 + 'ms';
            el.classList.add('is-in');
            io.unobserve(el);
          });
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
        els.forEach(function (el) { io.observe(el); });
      })();
    </script>
  </body>
</html>

---
// 記事詳細の本体マークアップ（日本語/英語ページで共用）。
// 本文(レンダリング済みMarkdown)はデフォルトスロットで受け取る。
import AffiliateLinks from './AffiliateLinks.astro';
import AffiliateRail from './AffiliateRail.astro';
import { useT, buildingTypeLabel, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  title: string;
  summary?: string;
  area: string;
  buildingType: 'office' | 'residence';
  verified: boolean;
  heroImage?: string;
  heroImageCredit?: string;
  heroImageLink?: string;
  specs: [string, string][];
  tags: string[];
  /** タグページへのリンク基底（'/tags/' or '/en/tags/'） */
  tagBase: string;
  sources: string[];
  /** パンくず「記事一覧」のリンク先（'/' or '/en/'） */
  listPath: string;
  /** アフィリエイト検索に使うJPキーワード（英語ページ用） */
  searchTitle?: string;
  searchArea?: string;
  /** 関連記事（内部リンク）。同エリア・近い竣工年の記事を呼び出し側で算出して渡す */
  related?: { title: string; area: string; href: string }[];
  /** 記事末の地図用。lat/lng があればピン精度、無ければ mapLabel(建物名)でジオコーディングする */
  lat?: number;
  lng?: number;
  mapLabel?: string;
}
const {
  lang, title, summary, area, buildingType, verified,
  heroImage, heroImageCredit, heroImageLink,
  specs, tags, tagBase, sources, listPath, searchTitle, searchArea,
  related = [],
  lat, lng, mapLabel,
} = Astro.props;
const t = useT(lang);
const typeLabel = buildingTypeLabel(lang, buildingType);
const commonsLabel = lang === 'ja' ? 'Wikimedia Commons' : 'via Wikimedia Commons';

// 地図クエリ: 緯度経度があればそれを優先、無ければ建物名（無ければタイトル）で検索。
const hasCoords = typeof lat === 'number' && typeof lng === 'number';
const mapQuery = hasCoords ? `${lat},${lng}` : (mapLabel ?? title);
const q = encodeURIComponent(mapQuery);
// APIキー不要の埋め込み（課金なし）。hl で地図ラベルの言語を切り替える。
const mapEmbedSrc = `https://maps.google.com/maps?q=${q}&z=16&hl=${lang}&output=embed`;
const mapsHref = `https://www.google.com/maps/search/?api=1&query=${q}`;
---
<p class="breadcrumb"><a href={listPath}>{t('breadcrumb.list')}</a> ／ {area}</p>
<article class="article">
  <div class="taglist">
    <span class={`badge ${buildingType}`}>{typeLabel}</span>
    {!verified && <span class="badge unverified">{t('badge.unverified')}</span>}
  </div>
  <h1>{title}</h1>
  {summary && <p class="lead">{summary}</p>}

  {heroImage && (
    <figure class="hero-figure">
      <img src={heroImage} alt={title} loading="lazy" />
      {heroImageCredit && (
        <figcaption>
          {t('photo.by')}: {heroImageLink
            ? <a href={heroImageLink} target="_blank" rel="nofollow noopener">{heroImageCredit}</a>
            : heroImageCredit} （{commonsLabel}）
        </figcaption>
      )}
    </figure>
  )}

  <dl class="spec">
    {specs.map(([k, v]) => (
      <div><dt>{k}</dt><dd>{v}</dd></div>
    ))}
  </dl>

  <slot />

  {related.length > 0 && (
    <nav class="related" aria-label={t('related.title')}>
      <h2>{t('related.title')}</h2>
      <ul class="related-list">
        {related.map((r) => (
          <li><a href={r.href}>{r.title}<span class="related-area">{r.area}</span></a></li>
        ))}
      </ul>
    </nav>
  )}

  <AffiliateLinks lang={lang} title={title} area={area} buildingType={buildingType} searchTitle={searchTitle} searchArea={searchArea} />

  {tags.length > 0 && (
    <div class="taglist" style="margin-top:28px">
      {tags.map((tag) => <a class="tag" href={`${tagBase}${encodeURIComponent(tag)}/`}>#{tag}</a>)}
    </div>
  )}

  {sources.length > 0 && (
    <section style="margin-top:24px">
      <h2>{t('sources.title')}</h2>
      <ul>{sources.map((s) => <li>{s.startsWith('http') ? <a href={s}>{s}</a> : s}</li>)}</ul>
    </section>
  )}

  <section class="map-section" aria-label={t('map.title')}>
    <h2>{t('map.title')}</h2>
    <div class="map-embed">
      <iframe
        title={`${title}${hasCoords ? '' : ` — ${t('map.title')}`}`}
        src={mapEmbedSrc}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>
    <p class="map-link">
      <a href={mapsHref} target="_blank" rel="noopener nofollow">{t('map.open')} ↗</a>
    </p>
  </section>
</article>

<AffiliateRail lang={lang} area={area} buildingType={buildingType} searchArea={searchArea} />

<style>
  .map-section { margin-top: 32px; }
  .map-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: rgba(0, 0, 0, 0.03);
  }
  .map-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .map-link {
    margin-top: 10px;
    font-size: 0.9rem;
  }
</style>

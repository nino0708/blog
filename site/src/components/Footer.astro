---
import { useT, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useT(lang);
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div>© {year} Built Japan — {t('site.tagline')}</div>
    <p class="disclaimer">{t('footer.disclaimer')}</p>
  </div>
</footer>

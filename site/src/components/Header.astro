---
import { useT, localizePath, type Lang } from '../i18n/ui';
import { CATEGORIES } from '../lib/category';

interface Props {
  lang: Lang;
  /** もう一方の言語での同一ページのパス。無ければその言語のトップへ。 */
  altPath?: string | null;
}
const { lang, altPath = null } = Astro.props;
const t = useT(lang);
const other: Lang = lang === 'ja' ? 'en' : 'ja';
const switchHref = altPath ?? localizePath(other, '/');
---
<header class="site-header">
  <div class="container inner">
    <a href={localizePath(lang, '/')} class="brand">
      <svg class="brand-mark" width="22" height="24" viewBox="0 0 22 24" aria-hidden="true">
        <rect x="2" y="9" width="6" height="14" rx="1" fill="var(--brand)" opacity="0.55" />
        <rect x="14" y="6" width="6" height="17" rx="1" fill="var(--brand)" opacity="0.75" />
        <rect x="8.5" y="1" width="5" height="22" rx="1" fill="var(--gold)" />
      </svg>
      <span class="brand-text">Built <span>Japan</span></span>
    </a>
    <nav class="nav">
      <a href={localizePath(lang, '/')}>{t('nav.home')}</a>
      <a href={localizePath(lang, '/database/')}>{t('nav.database')}</a>
      <a href={localizePath(lang, '/expressways/')}>{CATEGORIES.expressways.label[lang]}</a>
      <a href={localizePath(lang, '/railways/')}>{CATEGORIES.railways.label[lang]}</a>
      {/* 観光は日本語版のみ（英語コレクション未整備） */}
      {lang === 'ja' && <a href="/tourism/">{CATEGORIES.tourism.label.ja}</a>}
      {lang === 'ja' && <a href="/rankings/">ランキング</a>}
      <a href={localizePath(lang, '/about/')}>{t('nav.about')}</a>
      <a class="lang-switch" href={switchHref} hreflang={other} lang={other}>{t('lang.other')}</a>
    </nav>
  </div>
</header>

---
import { useT, buildingTypeLabel, buildCardMeta, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  url: string;
  title: string;
  buildingType: 'office' | 'residence';
  area: string;
  completedYear?: number;
  heightM?: number;
  summary?: string;
  verified: boolean;
  heroImage?: string;
}
const { lang, url, title, buildingType, area, completedYear, heightM, summary, verified, heroImage } = Astro.props;
const t = useT(lang);
const typeLabel = buildingTypeLabel(lang, buildingType, true);
const meta = buildCardMeta(lang, { area, completedYear, heightM });
---
<article
  class="card"
  data-reveal
  data-name={title.toLowerCase()}
  data-year={completedYear ?? ''}
  data-height={heightM ?? ''}
>
  <a href={url}>
    {heroImage
      ? <div class="thumb thumb-img"><img src={heroImage} alt={title} loading="lazy" /></div>
      : (
        <div class="thumb thumb-fallback">
          <span class="thumb-type">{typeLabel}</span>
          <span class="thumb-area">{area}</span>
          {heightM && <span class="thumb-height">{heightM}m</span>}
        </div>
      )}
    <div class="body">
      <div class="taglist">
        <span class={`badge ${buildingType}`}>{typeLabel}</span>
        {!verified && <span class="badge unverified">{t('badge.unverified.short')}</span>}
      </div>
      <h3>{title}</h3>
      <div class="meta">{meta}</div>
      {summary && <p class="summary">{summary}</p>}
    </div>
  </a>
</article>

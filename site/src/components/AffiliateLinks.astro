---
import {
  affiliateEnabled,
  rakutenTravelArea,
  rakutenBooksSearch,
  rakutenTravelLabel,
} from '../config/affiliate';
import { useT, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  title: string;
  area: string;
  buildingType: 'office' | 'residence';
  /** 検索に使うキーワード(日本語)。楽天/Amazonは日本語サービスのため、表示は英語でも検索語はJPを使う。 */
  searchTitle?: string;
  searchArea?: string;
}
const { lang, title, area, buildingType, searchTitle, searchArea } = Astro.props;
const t = useT(lang);
const kwTitle = searchTitle ?? title;
const kwArea = searchArea ?? area;
const noteHotel = lang === 'ja' ? '楽天トラベル' : 'Rakuten Travel';
const noteBooks = lang === 'ja' ? '楽天ブックス' : 'Rakuten Books';

// 地図リンク用のキーワード(建物名＋エリア)。楽天は日本語サービスなので英語ページでもJP語を使う。
const mapQuery = encodeURIComponent(`${kwTitle} ${kwArea}`);
const noteMap = lang === 'ja' ? 'Googleマップ' : 'Google Maps';

// 関連リンク。sponsored=アフィリエイト広告、それ以外(地図)は通常リンク。
const links = [
  {
    label: rakutenTravelLabel(kwArea, lang),
    note: noteHotel,
    url: rakutenTravelArea(kwArea),
    sponsored: true,
  },
  {
    label: t('affiliate.books'),
    note: noteBooks,
    url: rakutenBooksSearch(`東京 建築 ${buildingType === 'residence' ? 'マンション' : '超高層ビル'}`),
    sponsored: true,
  },
  {
    // 旧Amazon(成果リンク無効＆検索結果が無関係)を廃止し、建物の場所を地図で示す実用リンクに変更。
    label: lang === 'ja' ? 'Googleマップで場所を見る' : 'See the location on Google Maps',
    note: noteMap,
    url: `https://www.google.com/maps/search/?api=1&query=${mapQuery}`,
    sponsored: false,
  },
];
---
<section class="affiliate" aria-label={t('affiliate.aria')}>
  <div class="affiliate-head">
    <h2>{t('affiliate.title')}</h2>
    {affiliateEnabled && <span class="pr-badge">PR</span>}
  </div>
  {affiliateEnabled && (
    <p class="affiliate-disclosure">{t('affiliate.disclosure')}</p>
  )}
  <ul class="affiliate-list">
    {links.map((l) => (
      <li>
        <a href={l.url} target="_blank" rel={l.sponsored ? 'nofollow sponsored noopener' : 'noopener'}>
          {l.label}<span class="aff-note">{l.note} ↗</span>
        </a>
      </li>
    ))}
  </ul>
</section>
